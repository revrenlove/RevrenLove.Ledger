@page "/financial-accounts/{financialAccountId:guid}"

@using RevrenLove.Ledger.Api.Client
@using RevrenLove.Ledger.Api.Models
@using RevrenLove.Ledger.Shared

@inject ILedgerApiClient Client
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@if (financialAccount is null)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (!isEditing)
    {
        <h1>
            Financial Account Details
            <button type="button" class="btn btn-link" @onclick="ToggleEdit" title="Edit" aria-label="Edit financial account">✏️</button>
            <button type="button" class="btn btn-link" @onclick="Delete" title="Delete" aria-label="Delete financial account">🗑️</button>
        </h1>
        <div class="card mb-4">
            <div class="card-header">
                <h3>@financialAccount.FriendlyId - @financialAccount.Name</h3>
                @if (financialAccount.IsBalanceExempt)
                {
                    <span class="badge bg-info text-dark">Balance Exempt</span>
                }
            </div>
            <div class="card-body">
                <p>@financialAccount.Description</p>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="@editModel" OnValidSubmit="SaveChanges">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }
            <h1>
                Financial Account Details
                <button type="submit" class="btn btn-success btn-sm" title="Save" aria-label="Save financial account">✔️</button>
                <button type="button" class="btn btn-secondary btn-sm" @onclick="ClearEdit" title="Cancel" aria-label="Cancel editing financial account">🗙</button>
            </h1>
            <div class="card mb-4">
                <div class="card-header">
                    <div class="row g-2">
                        <div class="col-auto">
                            <label for="friendlyId" class="form-label">Friendly ID</label>
                            <InputText id="friendlyId" class="form-control" @bind-Value="editModel.FriendlyId" placeholder="Friendly ID" aria-required="true" aria-describedby="friendlyId-validation" />
                            <ValidationMessage For="@(() => editModel.FriendlyId)" id="friendlyId-validation" />
                        </div>
                        <div class="col">
                            <label for="accountName" class="form-label">Name</label>
                            <InputText id="accountName" class="form-control" @bind-Value="editModel.Name" placeholder="Name" aria-required="true" aria-describedby="accountName-validation" />
                            <ValidationMessage For="@(() => editModel.Name)" id="accountName-validation" />
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <label for="accountDescription" class="form-label">Description</label>
                    <InputTextArea id="accountDescription" class="form-control" @bind-Value="editModel.Description" placeholder="Description" rows="3" aria-describedby="accountDescription-validation" />
                    <ValidationMessage For="@(() => editModel.Description)" id="accountDescription-validation" />
                    <div class="form-check mt-2">
                        <InputCheckbox id="isBalanceExempt" class="form-check-input" @bind-Value="editModel.IsBalanceExempt" />
                        <label for="isBalanceExempt" class="form-check-label">Is Balance Exempt</label>
                    </div>
                </div>
            </div>
        </EditForm>
    }

    <h2>Ledger Transactions</h2>

    <div class="card mb-4">
        <div class="card-header">
            <h4>Add New Transaction</h4>
        </div>
        <div class="card-body">
            <EditForm Model="@newTransaction" OnValidSubmit="AddTransaction">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="row g-2">
                    <div class="col-md-2">
                        <label for="datePosted" class="form-label">Date</label>
                        <InputDate id="datePosted" class="form-control" @bind-Value="newTransaction.Date" aria-required="true" aria-describedby="datePosted-validation" />
                        <ValidationMessage For="@(() => newTransaction.Date)" id="datePosted-validation" />
                    </div>
                    <div class="col-md-3">
                        <label for="description" class="form-label">Description</label>
                        <InputText id="description" class="form-control" @bind-Value="newTransaction.Description" placeholder="Transaction description" aria-describedby="description-validation" />
                        <ValidationMessage For="@(() => newTransaction.Description)" id="description-validation" />
                    </div>
                    <div class="col-md-2">
                        <label for="status" class="form-label">Status</label>
                        <InputSelect id="status" class="form-control" @bind-Value="newTransaction.Status">
                            @foreach (var status in Enum.GetValues<FinancialTransactionStatus>())
                            {
                                <option value="@status">@status</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => newTransaction.Status)" id="status-validation" />
                    </div>
                    <div class="col-md-2">
                        <label for="destinationAccount" class="form-label">Destination Account</label>
                        <InputSelect id="destinationAccount" class="form-control" @bind-Value="newTransaction.DestinationFinancialAccountId">
                            <option value="">-- None --</option>
                            @foreach (var account in allAccounts.Where(a => a.Id != financialAccount!.Id))
                            {
                                <option value="@account.Id">@account.FriendlyId - @account.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => newTransaction.DestinationFinancialAccountId)" id="destinationAccount-validation" />
                    </div>
                    <div class="col-md-2">
                        <label for="amount" class="form-label">Amount</label>
                        <InputNumber step="0.01" id="amount" class="form-control" @bind-Value="newTransaction.Amount" aria-required="true" aria-describedby="amount-validation" />
                        <ValidationMessage For="@(() => newTransaction.Amount)" id="amount-validation" />
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100" aria-label="Add transaction">Add</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    @if (financialTransactions.Length == 0)
    {
        <p><em>No ledger transactions found for this financial account.</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Associated Transaction</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in financialTransactions)
                {
                    <tr>
                        <td>@transaction.Date.ToShortDateString()</td>
                        <td><a href="@($"/financial-transactions/{transaction.Id}")">@transaction.Description</a></td>
                        <td>@transaction.Amount.ToString("C")</td>
                        @if (transaction.AssociatedTransaction is not null)
                        {
                            <td>
                                <a href="@($"/financial-transactions/{transaction.AssociatedTransactionId}")">
                                    @transaction.AssociatedTransaction!.FinancialAccount!.Name
                                </a>
                            </td>
                        }
                        else
                        {
                            <td></td>
                        }
                        @if (transaction.Status == FinancialTransactionStatus.Pending)
                        {
                            <td><button type="button" class="btn btn-link" @onclick="() => PostTransaction(transaction)">Post</button></td>
                        }
                        else
                        {
                            <td></td>
                        }

                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter]
    public Guid FinancialAccountId { get; set; }

    private FinancialAccount? financialAccount;
    private FinancialTransaction[] financialTransactions = [];
    private FinancialAccount[] allAccounts = [];

    private FinancialAccount editModel = new();
    private CreateFinancialTransactionRequest newTransaction = new()
    {
        Amount = 0,
        Date = DateOnly.FromDateTime(DateTime.Now),
        Status = FinancialTransactionStatus.Pending
    };
    private bool isEditing = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadFinancialAccountDetails();
        await LoadLedgerTransactions();
        await LoadAllAccounts();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadFinancialAccountDetails();
        await LoadLedgerTransactions();
    }

    private async Task LoadFinancialAccountDetails()
    {
        var result = await Client.FinancialAccounts.GetAsync(FinancialAccountId);

        if (result.IsSuccessStatusCode)
        {
            financialAccount = result.Value;
        }
        else if (result.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            NavigationManager.NavigateTo("/financial-accounts");
        }
    }

    // BUG: This is fucked up. Not sure if it's the response or the rendering.
    private async Task LoadLedgerTransactions()
    {
        if (financialAccount is null)
        {
            return;
        }

        var result = await Client.FinancialTransactions.GetByFinancialAccountIdAsync(financialAccount.Id);
        if (result.IsSuccessStatusCode)
        {
            financialTransactions = result.Value!.ToArray();
        }
        else
        {
            // TODO: JE - handle errors
        }
    }

    private async Task LoadAllAccounts()
    {
        var result = await Client.FinancialAccounts.GetAsync();
        if (result.IsSuccessStatusCode)
        {
            allAccounts = result.Value!.ToArray();
        }
        else
        {
            // TODO: JE - handle errors
        }
    }

    private void ToggleEdit()
    {
        if (financialAccount is null)
        {
            return;
        }

        isEditing = true;
        editModel = financialAccount with { };
    }

    private async Task Delete()
    {
        if (financialAccount is null)
        {
            return;
        }

        // TODO: JE - better confirmation dialog
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Are you sure you want to delete '{financialAccount.Name}'? This action cannot be undone.");

        if (!confirmed)
        {
            return;
        }

        var result = await Client.FinancialAccounts.DeleteAsync(financialAccount.Id);

        if (result.IsSuccessStatusCode)
        {
            NavigationManager.NavigateTo("/financial-accounts");
        }
        else
        {
            // TODO: JE - better error handling
            errorMessage = "Unknown Error.";
        }
    }

    private async Task SaveChanges()
    {
        if (financialAccount is null)
        {
            return;
        }

        var result = await Client.FinancialAccounts.UpdateAsync(editModel);

        if (result.IsSuccessStatusCode)
        {
            financialAccount = result.Value;
            ClearEdit();
        }
        else
        {
            errorMessage = result.RawContent;
        }
    }

    private void ClearEdit()
    {
        isEditing = false;
        editModel = new();
        errorMessage = null;
    }

    private async Task AddTransaction()
    {
        if (financialAccount is null)
        {
            return;
        }

        newTransaction.FinancialAccountId = financialAccount.Id;

        var result = await Client.FinancialTransactions.CreateAsync(newTransaction);

        if (result.IsSuccessStatusCode)
        {
            newTransaction = new()
            {
                Amount = 0,
                Date = DateOnly.FromDateTime(DateTime.Now),
                Status = FinancialTransactionStatus.Pending
            };
            await LoadLedgerTransactions();
        }
        else
        {
            // TODO: JE - handle error
            errorMessage = result.RawContent;
        }
    }

    private async Task PostTransaction(FinancialTransaction transaction)
    {
        var result = await Client.FinancialTransactions.PostTransactionAsync(transaction.Id);
        
        if (result.IsSuccessStatusCode)
        {
            transaction.Status = FinancialTransactionStatus.Posted;
        }
        else
        {
            // TODO: JE - handle error
            errorMessage = result.ReasonPhrase;
        }
    }
}
